# Copy to `.env` and fill in.  Loaded by scripts/dev-up.sh; values
# also picked up by relay directly when run via `go run` / the docker
# image (config keys with dots become _).  See docs/deploy.md.
#
# .env is gitignored — DO NOT commit your filled-in copy.

# --- AI provider --------------------------------------------------------------
# stub | anthropic | deepseek | volcengine | moonshot | zhipu | dashscope |
# openai-compatible
APPUNVS_AI_BACKEND=stub

# Required when backend != stub.
# APPUNVS_AI_API_KEY=

# Optional model override.  Each backend has a sane default; set this
# when you want a specific model id (e.g. claude-opus-4-7,
# deepseek-reasoner, ep-... for Volcengine endpoint id).
# APPUNVS_AI_MODEL=

# Required ONLY for openai-compatible (no provider id) or when pointing
# at a self-hosted gateway in front of a known provider.
# APPUNVS_AI_BASE_URL=

# --- Sandbox builder ----------------------------------------------------------
# stub | docker.  stub returns a placeholder bundle that RuntimeView
# refuses to load — useful for backend-only tests; flip to docker for
# real publishes.
APPUNVS_SANDBOX_BACKEND=docker

# Image name DockerBuilder shells out to.  Defaults to appunvs/sandbox:latest;
# build via `bash runtime/packaging/build-sandbox.sh`.
# APPUNVS_SANDBOX_IMAGE=appunvs/sandbox:latest

# --- Networking ---------------------------------------------------------------
# Listen address; LAN dogfood usually leaves at default.
# APPUNVS_LISTEN=:8080

# Redis (sequencer + namespace stream).  appunvs-redis container is
# spun up by scripts/dev-up.sh on this address.
# APPUNVS_REDIS_ADDR=localhost:6379

# --- Misc ---------------------------------------------------------------------
# debug | info | warn | error
# APPUNVS_LOG_LEVEL=info
