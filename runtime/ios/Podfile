# Resolve react_native_pods.rb with node to allow for hoisting.
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Tell cocoapods which xcworkspace to write/update.  Without this,
# pod install can't auto-pick when two xcodeprojs (RuntimeSdk + the
# generated AppunvsRuntimeSDK) live in the same directory.  The
# workspace itself is created by the RN init's `npx init` and lives
# at runtime/ios/RuntimeSdk.xcworkspace.
workspace 'RuntimeSdk.xcworkspace'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

# `RuntimeSdk` is the RN init's dev-harness app target — its xcodeproj
# (RuntimeSdk.xcodeproj) was committed by `npx init`.
target 'RuntimeSdk' do
  project 'RuntimeSdk.xcodeproj'

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end

# D3.b's no-op of Pods-RuntimeSDK-resources.sh was needed because the SDK
# target had no use_native_modules! and the resources script still listed
# native-module bundles (RNSVG/RNSVGFilters.bundle etc.) — those bundles
# weren't built so archive failed.  D3.d brings those modules in via
# use_native_modules!, so the bundles are actually produced and the
# resources script's copies succeed.  The no-op is therefore removed.

# `RuntimeSDK` is the framework target we ship to host apps.  Lives in
# a SEPARATE xcodeproj (AppunvsRuntimeSDK.xcodeproj) generated by
# XcodeGen from SDK.yml — name avoids case collision with the RN
# init's RuntimeSdk.xcodeproj on macOS's case-insensitive APFS.
#
# D3.b: pulled in RN core + Hermes so the SDK can compile against React-
# Core, ReactCommon, hermes-engine.  No use_native_modules! at that point
# — autolinking would pull RNGestureHandler / RNReanimated / etc. in,
# but the host app's runtime hadn't yet been wired to receive them.
#
# D3.d (this PR): autolinks the Tier 1 modules listed in runtime/MODULES.md
# (reanimated / gesture-handler / screens / safe-area-context / svg / mmkv).
# These are pinned in runtime/package.json so use_native_modules! resolves
# to exactly those 6.  AI bundles can `import` them inside a SubRuntime.
target 'RuntimeSDK' do
  project 'AppunvsRuntimeSDK.xcodeproj'

  use_native_modules!
  use_react_native!(
    :path => '../node_modules/react-native',
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
end

# D3.c.4 iOS instrumented test scaffolding.  RuntimeFixtureApp is a
# minimal app that mounts a RuntimeView and loads the bundled fixture;
# RuntimeFixtureUITests is the XCUITest target that asserts the
# greeting rendered.  Both live in the same xcodeproj XcodeGen
# generates from SDK.yml.  The app gets its own Pods integration so
# RN's dyld libs (hermes-engine, React-Core, Tier 1 native modules)
# resolve at app link + load time.
target 'RuntimeFixtureApp' do
  project 'AppunvsRuntimeSDK.xcodeproj'

  use_native_modules!
  use_react_native!(
    :path => '../node_modules/react-native',
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
end
