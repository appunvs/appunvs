# Resolve react_native_pods.rb with node to allow for hoisting.
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Tell cocoapods which xcworkspace to write/update.  Without this,
# pod install can't auto-pick when two xcodeprojs (RuntimeSdk + the
# generated AppunvsRuntimeSDK) live in the same directory.  The
# workspace itself is created by the RN init's `npx init` and lives
# at runtime/ios/RuntimeSdk.xcworkspace.
workspace 'RuntimeSdk.xcworkspace'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

# `RuntimeSdk` is the RN init's dev-harness app target — its xcodeproj
# (RuntimeSdk.xcodeproj) was committed by `npx init`.
target 'RuntimeSdk' do
  project 'RuntimeSdk.xcodeproj'

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    # Strip "[CP] Copy Pods Resources" from the RuntimeSDK framework
    # target (lives in AppunvsRuntimeSDK.xcodeproj).  CocoaPods generates
    # that phase listing resources from every pod the target's xcconfig
    # references — including native-module bundles (RNSVG/RNSVGFilters.bundle,
    # etc.) that we deliberately don't link.  Archive fails because those
    # bundles aren't built for the framework target's BUILT_PRODUCTS_DIR.
    # Host apps bundle their own resources, so this phase is dead weight
    # for a brownfield framework.
    require 'xcodeproj'
    sdk_project = Xcodeproj::Project.open('AppunvsRuntimeSDK.xcodeproj')
    sdk_project.targets.each do |t|
      next unless t.name == 'RuntimeSDK'
      t.build_phases.delete_if do |phase|
        phase.respond_to?(:name) && phase.name == '[CP] Copy Pods Resources'
      end
    end
    sdk_project.save
  end
end

# `RuntimeSDK` is the framework target we ship to host apps.  Lives in
# a SEPARATE xcodeproj (AppunvsRuntimeSDK.xcodeproj) generated by
# XcodeGen from SDK.yml — name avoids case collision with the RN
# init's RuntimeSdk.xcodeproj on macOS's case-insensitive APFS.
#
# D3.b: pull in RN core + Hermes so the SDK can compile against React-
# Core, ReactCommon, hermes-engine.  Deliberately NO use_native_modules!
# — autolinking would pull RNGestureHandler / RNReanimated / etc. into
# the SDK framework itself, but those native modules want to be loaded
# by the host app, not bundled into a sibling framework.  D3.d figures
# out which Tier 1 modules (if any) actually belong inside the SDK.
target 'RuntimeSDK' do
  project 'AppunvsRuntimeSDK.xcodeproj'

  use_react_native!(
    :path => '../node_modules/react-native',
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
end
