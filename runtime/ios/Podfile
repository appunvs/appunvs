# Resolve react_native_pods.rb with node to allow for hoisting.
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

# `RuntimeSdk` is the RN init's dev-harness app target — its xcodeproj
# (RuntimeSdk.xcodeproj) was committed by `npx init`.
target 'RuntimeSdk' do
  project 'RuntimeSdk.xcodeproj'

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end

# `RuntimeSDK` is the framework target we ship to host apps.  Lives in
# a SEPARATE xcodeproj (RuntimeSDK.xcodeproj) generated by XcodeGen
# from SDK.yml.  Cocoapods needs the explicit `project` directive
# because it can't disambiguate two xcodeprojs in the same directory
# by target name alone.
#
# Build pipeline must run xcodegen BEFORE pod install so this xcodeproj
# exists when cocoapods integrates the target.
target 'RuntimeSDK' do
  project 'RuntimeSDK.xcodeproj'

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
end
