{
  "expo": {
    "name": "appunvs",
    "slug": "appunvs",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "appunvs",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appunvs.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan pairing QR codes."
      }
    },
    "android": {
      "package": "com.appunvs.app",
      "permissions": ["android.permission.CAMERA"],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
