{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "appunvs-desktop",
  "version": "0.1.0",
  "identifier": "com.appunvs.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../../app run web:dev",
    "beforeBuildCommand": "npm --prefix ../../app run web:export",
    "devUrl": "http://localhost:8081",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "appunvs desktop",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
